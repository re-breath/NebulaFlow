# Function: update_NebulaFlow
# Usage:    update_NebulaFlow
# Pull latest code from GitHub and reinstall.
# Dependencies: git, NebulaFlowinstaller.sh
update_NebulaFlow(){
    local initAddress=$(pwd)
    echo "Updating NebulaFlow..."
    mkdir -p update_temp
    cd update_temp
    git clone https://github.com/re-breath/NebulaFlow.git
    cd NebulaFlow
    bash NebulaFlowinstaller.sh
    cd $initAddress
    rm -rf update_temp
    echo "NebulaFlow update complete!"
}


# Function: relib — rebreath library file manager
# Usage:    relib [-v] [-m] <keyword1> [keyword2] ...
# Search ~/.rebreath/ by keywords and copy/view matching files.
#   -v  view only
#   -m  multi-keyword layered search
relib() {
    lib="$HOME/.rebreath"
    view=0
    multi=0
    args=()

    while [ $# -gt 0 ]; do
        case "$1" in
            -v) view=1 ;;
            -m) multi=1 ;;
            *)  args+=("$1") ;;
        esac
        shift
    done

    if [ ${#args[@]} -eq 0 ]; then
        echo "Please provide at least one search keyword."
        exit 521
    fi

    tmpfile=$(mktemp)
    find "$lib" -type f -name "*${args[0]}*" > "$tmpfile"

    for keyword in "${args[@]:1}"; do
        new_tmpfile=$(mktemp)
        while IFS= read -r line; do
            find "$line" -type f -name "*$keyword*" >> "$new_tmpfile"
        done < "$tmpfile"
        mv "$new_tmpfile" "$tmpfile"
    done

    if [ $view -eq 1 ]; then
        cat "$tmpfile"
    else
        while IFS= read -r line; do
            cp "$line" ./
        done < "$tmpfile"
    fi
    rm -f "$tmpfile"
}


