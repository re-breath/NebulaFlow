# Function: recc  —  Record file paths to memory
# Usage:    recc file1.txt file2.xyz
# Record absolute paths of files for later batch operations.
recc(){
    local cc_tmpfile="/tmp/cc_fzmrkwjsbzz_pointer"
    for i in "$@"; do
        local fileaddress=$(realpath "$i")
        echo "$fileaddress" >> "$cc_tmpfile"
        echo "File $fileaddress remembered"
    done
}

# Function: reclean  —  Clear remembered file list
# Usage:    reclean
reclean(){
    local cc_tmpfile="/tmp/cc_fzmrkwjsbzz_pointer"
    if [ -f "$cc_tmpfile" ]; then
        > "$cc_tmpfile"
        echo "Memory cleared!"
    fi
}

# Function: recat  —  View remembered file list
# Usage:    recat
recat(){
    local cc_tmpfile="/tmp/cc_fzmrkwjsbzz_pointer"
    if [ -f "$cc_tmpfile" ]; then
        cat "$cc_tmpfile"
    else
        echo "Temp file not found. Run recc first."
    fi
}

# Function: revv  —  Copy remembered files to target dir
# Usage:    revv [target_dir]
revv(){
    local cc_tmpfile="/tmp/cc_fzmrkwjsbzz_pointer"
    local vv_dir=${1:-.}
    if [ -f "$cc_tmpfile" ]; then
        cat "$cc_tmpfile" | xargs -I {} cp -t "$vv_dir" {}
    else
        echo "Temp file not found. Run recc first."
    fi
}

# Function: wslcd  —  Smart cd with Windows-path detection
# Usage:    wslcd D:\NebulaFlow
function wslcd() {
    local wsl_dir=$1
    if [[ $wsl_dir =~ ^([a-zA-Z]):(.*)$ ]]; then
        local drive=$(echo ${BASH_REMATCH[1]} | tr '[:upper:]' '[:lower:]')
        local path=${BASH_REMATCH[2]}
        path=$(echo $path | sed 's|\\|/|g')
        local wsl_path="/mnt/${drive}${path}"
        echo "Converted WSL path: $wsl_path"
        cd  -- "$wsl_path"
    else
        cd  -- "$wsl_dir"
    fi
}

# Function: winpath  —  Convert Windows path to WSL (output only)
# Usage:    winpath D:\NebulaFlow
winpath(){
    local wsl_dir=$1
    if [[ $wsl_dir =~ ^([a-zA-Z]):(.*)$ ]]; then
        local drive=$(echo ${BASH_REMATCH[1]} | tr '[:upper:]' '[:lower:]')
