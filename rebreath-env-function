}

# Function: wc_file_lines  —  Count code lines by extension
# Usage:    wc_file_lines cpp h py
wc_file_lines() {
    if [ $# -eq 0 ]; then
        echo "Usage: wc_file_lines <suffix1> [suffix2] ..."
        return 1
    fi
    local find_args=()
    local first=1
    for ext in "$@"; do
        if [ $first -eq 1 ]; then first=0; else find_args+=(-o); fi
        find_args+=(-name "*.$ext")
    done
    find . -type f \( "${find_args[@]}" \) -exec wc -l {} + | sort -nr | head -n 6 | tail -n 5
    echo "Total lines in all specified files:"
    find . -type f \( "${find_args[@]}" \) -exec wc -l {} + | tail -n 1 | awk '{print $1}'
}


