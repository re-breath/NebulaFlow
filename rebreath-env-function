# Function: pow  —  Integer exponentiation
# Usage:    pow 2 10   => 1024
pow(){
    local base=$1
    local exp=$2
    echo $((base**exp))
}

# Function: calc_time  —  Measure command execution time
# Usage:    calc_time "gpumd"
calc_time(){
    local start_time=$(date +%s%3N)
    eval "$@"
    local end_time=$(date +%s%3N)
    local time_diff=$((end_time-start_time))
    echo "Elapsed: $time_diff ms"
}

