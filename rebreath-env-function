# Function: gpt9  —  Simple chatbot toy
# Usage:    gpt9  (type "exit" to quit)
gpt9() {
    echo "hallo, I'm gpt9!"
    while true; do
        echo -en "\e[33m$USER: \e[0m"
        read -r line
        case "$line" in
            exit|Exit|EXIT) echo "gpt9: Bye!"; break ;;
            *)
                processed_line=$(echo "$line" | sed -e 's/吗//g; s/you//g; s/?/!/g; s/^你/我/g; s/我/你/g; s/吧//g; s/？/！/g')
                echo -e "\e[32mgpt9: \e[0m $processed_line\n"
                ;;
        esac
    done
}

