# Function: proxy_download
# Usage:    proxy_download "wget http://example.com/file.tar.gz"
# Download files via SSH proxy to local machine.
proxy_download() {
    local remote_server="dhk@10.14.0.15"
    local remote_path="/home/dhk/rebreath/proxy_downfiles"
    local remote_temp_path="${remote_path}/temp"

    ssh -i ~/.ssh/id_rsa ${remote_server} "mkdir -p ${remote_temp_path} && cd ${remote_temp_path} && $1"

    if [[ "$?" -ne 0 ]]; then
        echo "Download failed; check command and retry."
        return 1
    fi

    scp -rv -i ~/.ssh/id_rsa ${remote_server}:${remote_temp_path}/* .

    if [[ "$?" -ne 0 ]]; then
        echo "File copy failed; check remote paths."
        return 1
    fi

    ssh -i ~/.ssh/id_rsa ${remote_server} "rm -rf ${remote_temp_path}/*"
    echo "File downloaded successfully and temp cleaned."
}


