wc_file_lines() {
    # 用法: wc_file_lines cpp h
    # 查找当前目录及其子目录下所有指定后缀的文件
    # 统计每个文件行数，按行数倒序输出前5个文件
    # 最后输出这些文件的总行数

    if [ $# -eq 0 ]; then
        echo "用法: wc_file_lines <suffix1> [suffix2] ..."
        return 1
    fi

    local find_args=()
    local first=1

    for ext in "$@"; do
        if [ $first -eq 1 ]; then
            first=0
        else
            find_args+=(-o)
        fi
        find_args+=(-name "*.$ext")
    done

    find . -type f \( "${find_args[@]}" \) -exec wc -l {} + | \
        sort -nr | head -n 6 | tail -n 5

    echo "Total lines in all specified files:"
    find . -type f \( "${find_args[@]}" \) -exec wc -l {} + | \
        tail -n 1 | awk '{print $1}'
}

