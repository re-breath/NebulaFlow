# Function: pwdxcd  —  cd to working dir of a PID
# Usage:    pwdxcd <PID>
pwdxcd() {
    if [ $# -ne 1 ]; then
        echo "Usage: pwdxcd <PID>"
        return 1
    fi
    local dir
    dir=$(pwdx "$1" 2>/dev/null | awk -F ': ' '{print $2}')
    if [ -z "$dir" ] || [ ! -d "$dir" ]; then
        echo "Error: cannot get valid working directory for PID $1"
        return 1
    fi
    cd -- "$dir"
}

# Function: wait_and_run
# Usage:    wait_and_run <PID> "command" [interval_seconds]
# Wait for PID to finish, then execute command on free GPU.
wait_and_run () {
    local pid=$1
    local cmd=${2}
    local interval=${3:-60}
    if [ -z "$pid" ]; then
        echo "Usage: wait_and_run <PID> [command] [interval]"
        return 1
    fi
    echo "Watching PID $pid (interval: ${interval}s)..."
    while kill -0 "$pid" 2>/dev/null; do
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] PID $pid still running..."
        sleep "$interval"
    done
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] PID $pid finished. Starting follow-up..."
    free_time_run "$cmd"
}

