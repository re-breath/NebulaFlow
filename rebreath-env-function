# Function: compute_high_of_tree
# Usage:    compute_high_of_tree
# Teaching example: dynamically generate, compile and execute C++ from Shell.
compute_high_of_tree() {
    local tmpdir=$(mktemp -d -t high_of_tree-XXXXXX)
    pushd "$tmpdir"
    cat > high_of_tree.cpp <<EOF
    #include <iostream>
    #include <cmath>
    #include <numbers>
    using namespace std;
    void high_of_tree(){
        const double pi{std::numbers::pi};
        double high{}, h{}, d{}, angle{};
        cout << "Calculate tree height" << endl;
        cout << "please enter h, d, angle: ";
        cin >> h >> d >> angle;
        cout << "h = " << h << "  d = " << d << "  angle = " << angle << endl;
        cout << "Tree height = " << h + d * std::tan(angle * pi / 180) << endl;
    }
    int main(){ high_of_tree(); return 0; }
EOF
    g++ -std=c++20 high_of_tree.cpp -o high_of_tree
    ./high_of_tree
    popd
    rm -rf "$tmpdir"
}


