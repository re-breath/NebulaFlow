# 该脚本使用来与自研MD软件LSMD进行对比，可以输出OPLSaa势能各个组分的能量，力，压强，位力。
# ---------------- Bond-only ----------------
clear
units       real
atom_style  full

bond_style      harmonic
angle_style     zero nocoeff
dihedral_style  zero nocoeff
pair_style      zero 10.0 nocoeff

read_data   eqoptedsort.data

thermo      1
thermo_style custom step etotal ebond eangle edihed evdwl ecoul  press pxx pyy pzz pxy pxz pyz  

compute     f_bond all property/atom fx fy fz

variable        Fx atom c_f_bond[1]/(23.0609)
variable        Fy atom c_f_bond[2]/(23.0609)
variable        Fz atom c_f_bond[3]/(23.0609)

dump        dump_bond all custom 1 bondforce.log id type x y z v_Fx v_Fy v_Fz

dump_modify dump_bond sort id
dump_modify dump_bond format float %14.6f
dump_modify dump_bond format int %8d

# 每原子位力（只取势能部分 virial，不含动能）
compute         s all stress/atom NULL virial
variable        Vol equal vol


# 定义变量：去掉负号（stress/atom 是负的位力），并把 kcal/mol 转换为 eV
variable        Wxx atom -c_s[1]/(23.0609*${Vol})
variable        Wyy atom -c_s[2]/(23.0609*${Vol})
variable        Wzz atom -c_s[3]/(23.0609*${Vol})
variable        Wxy atom -c_s[4]/(23.0609*${Vol})
variable        Wxz atom -c_s[5]/(23.0609*${Vol})
variable        Wyz atom -c_s[6]/(23.0609*${Vol})


# 输出到文件：每原子的 6 分量位力，单位 eV
dump            v_all all custom 1 virialbond.dump id type v_Wxx v_Wyy v_Wzz v_Wxy v_Wxz v_Wyz
dump_modify v_all sort id
dump_modify v_all format float %14.6f
dump_modify v_all format int %8d

timestep    0
fix         nve_bond all nve
run         0
unfix       nve_bond
undump      dump_bond
uncompute   f_bond

